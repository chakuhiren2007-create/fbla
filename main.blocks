p"><field name="TEXT">Hi! I'm Christopher Columbus!</field></shadow></value><value name="timeOnScreen"><shadow type="timePicker" id="/My.3{xm[$~i1Y$%57_z"><field name="ms">5000</field></shadow></value><value name="animated"><shadow type="logic_boolean" id="DQ;p#nJ-b#QfXA8WiXT-"><field name="BOOL">FALSE</field></shadow></value><next><block type="device_pause" id="=U}wg;%*]{?VLOaDmy-1"><value name="pause"><shadow type="timePicker" id="mp9DwE;xdN:v+[)??6)D"><field name="ms">4000</field></shadow></value><next><block type="spritesaytext" id=")pM.~9!?+*qn:n|B#5W!"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="this"><block type="variables_get" id="WJI4HJot%Z;}2ZC(%B-["><field name="VAR" id="]]:$X3s,U/By$im~Eq]@">CColumbos</field></block></value><value name="text"><shadow type="text" id="B7p/bcpG!auF?VIU+_ot"><field name="TEXT">Nice to meet you!</field></shadow></value><value name="timeOnScreen"><shadow type="timePicker" id="c)%O=ZQ+W-@,p{Pm*mU#"><field name="ms">2000</field></shadow></value><value name="animated"><shadow type="logic_boolean" id="i1`A(b{onsc@.VSj*N|W"><field name="BOOL">FALSE</field></shadow></value><next><block type="device_pause" id="DoPCT!Y7p/+6P,t_aIDE"><value name="pause"><shadow type="timePicker" id="RZ@a~^w5|p1$0w;Wi;an"><field name="ms">4000</field></shadow></value><next><block type="spritesaytext" id="hG5[eYuc_{fYf}?PQcmU"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="this"><block type="variables_get" id="_/*I#^!x3-P#z.gdEown"><field name="VAR" id="]]:$X3s,U/By$im~Eq]@">CColumbos</field></block></value><value name="text"><shadow type="text" id="R}H=+Z6w;I-UBbg3n_ha"><field name="TEXT">Wow, can't believe I am in Asia! I am going to call this place San Salvador!</field></shadow></value><value name="timeOnScreen"><shadow type="timePicker" id="o{REvLrQZPIRRWa6J|%@"><field name="ms">5000</field></shadow></value><value name="animated"><shad