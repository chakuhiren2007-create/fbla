I"><field name="TEXT">Hi! I'm Christopher Columbus!</field></shadow></value><value name="timeOnScreen"><shadow type="timePicker" id="9.17Y9vWx]cSf[sh?9kP"><field name="ms">5000</field></shadow></value><value name="animated"><shadow type="logic_boolean" id="EGDQ`rxNR~t4-~J%S(]Q"><field name="BOOL">FALSE</field></shadow></value><next><block type="device_pause" id="Z9Kr=oS#(s$.A*_5I:6("><value name="pause"><shadow type="timePicker" id="QFCN3gbT:;`KJ(q3FFHM"><field name="ms">4000</field></shadow></value><next><block type="spritesaytext" id="CJwR{+[96Yf9SlnvGABi"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="this"><block type="variables_get" id="Ypi2|tj)GGdXB*2e*oQ_"><field name="VAR" id="`Kmf?Hh3GcAzx+GxI)qX">CColumbos</field></block></value><value name="text"><shadow type="text" id="@X@xj#P%1e+M4|Ib,;#6"><field name="TEXT">Nice to meet you!</field></shadow></value><value name="timeOnScreen"><shadow type="timePicker" id="$nIaErCq{J2jpmKF-$hm"><field name="ms">2000</field></shadow></value><value name="animated"><shadow type="logic_boolean" id="U!aELmkdV5Bl=9^e$3@["><field name="BOOL">FALSE</field></shadow></value><next><block type="device_pause" id="?buHO(38jS-.Qp6my_Q="><value name="pause"><shadow type="timePicker" id="jOuKgcX~e@5mm%hLE:fp"><field name="ms">4000</field></shadow></value><next><block type="spritesaytext" id="|)=NO!s~@NppEx,[bx7y"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="this"><block type="variables_get" id="S+I6aH}c3mUd~-{~Lc6z"><field name="VAR" id="`Kmf?Hh3GcAzx+GxI)qX">CColumbos</field></block></value><value name="text"><shadow type="text" id="po4))iV;Af^O5_5kgoLs"><field name="TEXT">Wow, can't believe I am in Asia! I am going to call this place San Salvador!</field></shadow></value><value name="timeOnScreen"><shadow type="timePicker" id="$FXHAWj,D#:YcsL3DSDv"><field name="ms">5000</field></shadow></value><value name="animated"><shad